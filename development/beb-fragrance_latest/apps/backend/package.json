{
  "name": "@beb/backend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "node kill-port.js && nodemon",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "db:generate": "prisma generate --schema=src/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=src/prisma/schema.prisma",
    "db:seed": "ts-node -r tsconfig-paths/register src/prisma/seed.ts",
    "db:studio": "prisma studio --schema=src/prisma/schema.prisma"
  },
  "prisma": {
    "schema": "src/prisma/schema.prisma",
    "seed": "ts-node -r tsconfig-paths/register src/prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "compression": "^1.7.4",
    "express-rate-limit": "^7.3.0",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "zod": "^3.23.8",
    "dotenv": "^16.4.5",
    "redis": "^4.6.14",
    "ioredis": "^5.3.2",
    "multer": "^1.4.5-lts.1",
    "@aws-sdk/client-s3": "^3.583.0",
    "@aws-sdk/s3-request-presigner": "^3.583.0",
    "axios": "^1.7.2",
    "winston": "^3.13.0",
    "uuid": "^10.0.0",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/morgan": "^1.9.9",
    "@types/compression": "^1.7.5",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/bcryptjs": "^2.4.6",
    "@types/multer": "^1.4.11",
    "@types/uuid": "^10.0.0",
    "@types/node": "^20.14.2",
    "typescript": "^5.4.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "nodemon": "^3.1.3",
    "prisma": "^5.14.0",
    "@beb/shared": "*"
  }
}