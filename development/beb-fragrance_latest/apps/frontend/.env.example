# ============================================
# APP CONFIGURATION
# ============================================
NEXT_PUBLIC_APP_NAME=BEB Fragrance
NEXT_PUBLIC_APP_DESCRIPTION=Uzbek Premium Fragrance E-commerce Platform
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_VERSION=1.0.0

# ============================================
# API CONFIGURATION
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_API_TIMEOUT=30000
NEXT_PUBLIC_API_VERSION=v1

# ============================================
# AUTHENTICATION
# ============================================
NEXTAUTH_SECRET=your-secret-key-here-change-in-production
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_JWT_SECRET=your-jwt-secret-here
NEXT_PUBLIC_JWT_EXPIRES_IN=7d
NEXT_PUBLIC_REFRESH_TOKEN_EXPIRES_IN=30d

# ============================================
# PAYMENT PROVIDERS
# ============================================
NEXT_PUBLIC_PAYME_MERCHANT_ID=your-payme-merchant-id
PAYME_MERCHANT_KEY=your-payme-merchant-key
NEXT_PUBLIC_CLICK_SERVICE_ID=your-click-service-id
NEXT_PUBLIC_CLICK_MERCHANT_ID=your-click-merchant-id
CLICK_MERCHANT_KEY=your-click-merchant-key
NEXT_PUBLIC_CLICK_RETURN_URL=http://localhost:3000/checkout/result

# ============================================
# STORAGE & FILE UPLOAD
# ============================================
NEXT_PUBLIC_AWS_S3_BUCKET=your-s3-bucket-name
NEXT_PUBLIC_AWS_S3_REGION=us-east-1
AWS_S3_ACCESS_KEY_ID=your-aws-access-key
AWS_S3_SECRET_ACCESS_KEY=your-aws-secret-key
NEXT_PUBLIC_AWS_S3_CDN_URL=https://your-cdn-url.s3.amazonaws.com
NEXT_PUBLIC_MAX_FILE_SIZE=5

# ============================================
# THIRD-PARTY SERVICES
# ============================================
TELEGRAM_BOT_TOKEN=8871529830:AAGRIG_8BrUJPFmqCSh7uyIPAbq6a4o_oJM
TELEGRAM_ADMIN_CHAT_ID=your-telegram-chat-id
SMS_PROVIDER_API_KEY=your-sms-api-key
SMS_PROVIDER_API_URL=https://sms-api.example.com
EMAIL_SERVICE_API_KEY=your-email-service-key
EMAIL_SERVICE_PROVIDER=sendgrid

# ============================================
# ANALYTICS & MONITORING
# ============================================
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXXXXX
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development

# ============================================
# FEATURE FLAGS
# ============================================
NEXT_PUBLIC_FEATURE_CATALOG=true
NEXT_PUBLIC_FEATURE_CART=true
NEXT_PUBLIC_FEATURE_ORDERS=true
NEXT_PUBLIC_FEATURE_PAYME=true
NEXT_PUBLIC_FEATURE_CLICK=true
NEXT_PUBLIC_FEATURE_CASH=true
NEXT_PUBLIC_FEATURE_GIFT_BOX=true
NEXT_PUBLIC_FEATURE_SCENT_PROFILE=true
NEXT_PUBLIC_FEATURE_ADMIN=false
NEXT_PUBLIC_FEATURE_NOTIFICATIONS=true

# ============================================
# LOCALIZATION
# ============================================
NEXT_PUBLIC_DEFAULT_LOCALE=uz
NEXT_PUBLIC_SUPPORTED_LOCALES=uz,ru

# ============================================
# SEO
# ============================================
NEXT_PUBLIC_GOOGLE_SEARCH_VERIFICATION=
NEXT_PUBLIC_YANDEX_VERIFICATION=

# ============================================
# DEVELOPMENT
# ============================================
NEXT_PUBLIC_DEBUG=false
NEXT_PUBLIC_MOCK_API=false
NEXT_PUBLIC_API_DELAY=0
