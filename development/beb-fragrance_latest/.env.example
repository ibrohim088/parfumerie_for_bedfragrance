# =============================================================
#  BEB FRAGRANCE — ENV NAMUNASI
#  Har bir app o'z .env fayliga ega. Bu fayl umumiy ko'rinish.
# =============================================================


# ── DATABASE ──────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/beb_fragrance


# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d


# ── REDIS ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379


# ── AWS S3 (rasm saqlash) ─────────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_BUCKET_NAME=beb-fragrance
AWS_REGION=us-east-1


# ── SMS — Eskiz.uz ────────────────────────────────────────────
SMS_EMAIL=your@email.com
SMS_SECRET=your_eskiz_secret


# ── PAYME ─────────────────────────────────────────────────────
PAYME_MERCHANT_ID=your_merchant_id_from_payme_uz
PAYME_SECRET_KEY=your_secret_key_from_payme_uz
PAYME_TEST_MODE=true
# Callback: https://api.bebfragrance.uz/payments/payme/callback


# ── CLICK ─────────────────────────────────────────────────────
CLICK_MERCHANT_ID=your_merchant_id
CLICK_SERVICE_ID=your_service_id
CLICK_SECRET_KEY=your_secret_key
# Prepare:  https://api.bebfragrance.uz/payments/click/prepare
# Complete: https://api.bebfragrance.uz/payments/click/complete


# ── PAYMENT GENERAL ───────────────────────────────────────────
PAYMENT_CALLBACK_BASE_URL=https://api.bebfragrance.uz
CASH_MIN_AMOUNT=10000
CASH_MAX_AMOUNT=10000000


# ── TELEGRAM BOT ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
ADMIN_CHAT_ID=your_telegram_chat_id
WEBAPP_URL=https://bebfragrance.uz
API_BASE_URL=https://api.bebfragrance.uz


# ── FRONTEND (Next.js) ────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.bebfragrance.uz
NEXTAUTH_SECRET=your_nextauth_secret_min_32_chars
NEXTAUTH_URL=https://bebfragrance.uz
NEXT_PUBLIC_PAYME_MERCHANT_ID=your_payme_merchant_id
NEXT_PUBLIC_CLICK_MERCHANT_ID=your_click_merchant_id
NEXT_PUBLIC_CLICK_SERVICE_ID=your_click_service_id


# ── ADMIN DASHBOARD (Next.js) ─────────────────────────────────
# NEXT_PUBLIC_API_URL=https://api.bebfragrance.uz
# NEXTAUTH_SECRET=your_admin_nextauth_secret
# NEXTAUTH_URL=https://admin.bebfragrance.uz


# ── SERVER ────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
